<!-- HERO SECTION -->
        <section class=" bg-{{background}} w-full overflow-x-clip z-10 xl:pl-[var(--container-px)] ">

            <div class="flex flex-col relative max-w-480 mx-auto overflow-x-clip container-pt">
                <!-- overall div -->
                <div class="flex flex-col gap-12.5 md:gap-14.75 xl:flex xl:flex-row xl:justify-between xl:gap-6">
                    <!-- heading and button -->
                    <div
                        class="flex flex-col gap-8 md:gap-12 lg:basis-1/2 justify-center px-[var(--container-px)] xl:px-0 xl:pb-20">
                        <!-- thsis is heading and p tag div -->
                        <div class="flex flex-col gap-6 md:gap-10">
                            <h1 class="font-primary  max-w-166 text-h1 2xl:max-w-150">{{title}}</h1>
                            <div class="font-secondary text-base leading-7 lg:text-lg lg:leading-7.5 xl:leading-8.5 xl:text-xl text-tertiary/80  md:max-w-135">{{description}}</div>
                        </div>
                      {{cta}}
                        <div class="flex flex-col md:flex-row md:justify-between md:items-center max-w-150 gap-5">
                            <div class="flex items-center gap-3.25 py-2.5 w-full md:w-fit  xl:py-0" >
                                <h2 class="text-h4 basis-1/5">{{years}}</h2>
                                <span class="text-sm">{{yearstext}}</span>

                            </div>
                            <div class="h-0.5 w-full md:w-0.5 md:h-10 bg-secondary"></div>

                            <div class="flex items-center xl:justify-center w-full md:w-fit gap-3.25 py-2.5 xl:py-0  ">
                                <h2 class="text-h4 basis-1/5">{{projects}}</h2>
                                <span class="text-sm font-secondary">{{projectstext}}</span>
                            </div>
                            <div class="h-0.5 w-full md:w-0.5 md:h-10 bg-secondary"></div>
                            <div
                                class="flex items-center justify-start w-full md:w-fit gap-3.25 py-2.5 xl:justify-center xl:py-0 whitespace-nowrap">
                                <div class="basis-1/5" >
                                    <img src="{{clientsimage}}"  class="w-full h-auto">
                                </div>

                                <span class="font-tertiary w-fit text-sm">{{subtitle}}</span>
                            </div>
                        </div>
                    </div>
                    <!-- image div  -->
                    <div class="xl:basis-1/2 h-[clamp(530px,85vw,920px)] xl:h-auto relative xl:static overflow-hidden">
                        <div
                            class=" aspect-square h-[110%] xl:h-auto xl:w-[clamp(830px,60vw,1054px)] rounded-full absolute -top-1/10 -right-50 sm:-right-1/5 md:-right-1/5 xl:-top-1/5 xl:-right-50 2xl:-top-3/10">
                            <img src="{{image}}" class="w-full aspect-square rounded-full object-cover">
                        </div>
                    </div>
                </div>
            </div>

        </section>