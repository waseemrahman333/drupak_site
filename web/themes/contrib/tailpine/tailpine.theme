function tailpine_form_alter(&$form, \Drupal\Core\Form\FormStateInterface $form_state, $form_id) {
  if ($form_id === 'user_login_form') {

    // Add a beautiful logo and heading section.
    $form['custom_title'] = [
      '#type' => 'markup',
      '#markup' => '
        <div class="text-center mb-8 animate-fade-in">
          <img src="/themes/custom/tailpine/logo.svg" alt="Logo" class="mx-auto w-40 h-20 mb-4 drop-shadow-md">
          <h2 class="text-3xl font-extrabold bg-gradient-to-r from-primary via-tertiary to-secondary bg-clip-text text-transparent">
            Welcome Back 👋
          </h2>
          <p class="text-gray-700 mt-2">Log in to your account and continue your journey</p>
        </div>
      ',
      '#weight' => -100,
    ];

    // Wrap the form in a beautiful card container.
    $form['#prefix'] = '<div class="flex items-center justify-center min-h-screen ">
                          <div class="backdrop-blur-md bg-white/10 border  mx-auto border-gray-700 p-8 sm:p-12 w-full max-w-xl transform transition duration-500">';
    $form['#suffix'] = '</div></div>';

// Username field.
$form['name']['#prefix'] = '
<div class="relative w-full">

';

$form['name']['#suffix'] = '</div>';

$form['name']['#attributes']['class'][] = 'w-full  pr-4 py-3 mb-4 border border-gray-700 bg-white/5 text-gray-200 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all duration-300 rounded-lg';
$form['name']['#attributes']['placeholder'] = t('Username or Email');


    // Password field.
    $form['pass']['#attributes']['class'][] = 'w-full  pr-4 py-3 mb-4 sborder border-gray-700 bg-white/5  placeholder-gray-400  focus:outline-none focus:ring-2 focus:ring-indigo-500 transition-all duration-300';
    $form['pass']['#attributes']['placeholder'] = t('Password');

    // Login button.
    $form['actions']['submit']['#attributes']['class'][] = 'w-full py-3 px-4 cursor-pointer font-semibold text-lg text-white bg-gradient-to-r from-primary  to-secondary  focus:ring-4 focus:ring-secondary  transition-all duration-500 ease-in-out transform ';
    $form['actions']['#attributes']['class'][] = 'flex justify-center mt-4';

    // Add footer links (e.g., Forgot password or signup).
    $form['footer_links'] = [
      '#type' => 'markup',
      '#markup' => '
        <div class="text-center mt-8 text-gray-700 text-sm">
          <a href="/user/password" class="hover:text-primary transition">Forgot your password?</a><br>
          <a href="/user/register" class="hover:text-secondary transition">Create a new account</a>
        </div>
      ',
      '#weight' => 100,
    ];
  }
}

/**
 * Implements hook_preprocess_HOOK() for HTML document templates.
 *
 * Adds 'type' to input.html.twig
 */
function tailpine_preprocess_input(&$variables) {
  // Get the input type.
  $type = $variables['element']['#type'] ?? '';
  $variables['type'] = $type;
}

/**
 * Implements hook_preprocess_block__system_messages_block().
 */
function tailpine_preprocess_block__system_messages_block(&$variables) {
 $variables['content'] = StatusMessages::renderMessages();
}

function tailpine_preprocess_paragraph__tailpine_slider(&$variables) {
  $variables['#attached']['library'][] = 'tailpine/slick';
}
