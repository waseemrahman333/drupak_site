<?php

use Drupal\Core\Form\FormStateInterface;
use Drupal\Core\Messenger\MessengerInterface;
use Drupal\Core\Render\Element\StatusMessages;
use Drupal\Core\Url;

/**
 * @file
 * Functions to support theming.
 */
/**
 * Implements hook_preprocess_image_widget().
 */
function tailpine_preprocess_image_widget(array &$variables): void
{
  $data = &$variables['data'];

  // This prevents image widget templates from rendering preview container HTML
  // to users that do not have permission to access these previews.
  // @todo revisit in https://drupal.org/node/953034
  // @todo revisit in https://drupal.org/node/3114318
  if (isset($data['preview']['#access']) && $data['preview']['#access'] === FALSE) {
    unset($data['preview']);
  }
}

/**
 * Implements hook_preprocess_HOOK() for HTML document templates.
 *
 * Adds body classes if certain regions have content.
 */
function tailpine_preprocess_html(&$variables)
{
  if (!isset($variables['attributes']['class'])) {
    $variables['attributes']['class'] = [];
  }

  // Color settings
  if (theme_get_setting('tailpine_enable_color')) {
    $pc = theme_get_setting('tailpine_base_primary_color') ?? '#10B981';
    $sc = theme_get_setting('tailpine_base_secondary_color') ?? '#064E3B';
    $tc = theme_get_setting('tailpine_base_tertiary_color') ?? '#06B6D4';
    $bc = theme_get_setting('tailpine_body_color') ?? '#1F2937';
    $bgc = theme_get_setting('tailpine_body_bg_color') ?? '#FFFFFF';
    $h1c = theme_get_setting('tailpine_h1_color') ?? '#1F2937';
    $h2c = theme_get_setting('tailpine_h2_color') ?? '#1F2937';
    $h3c = theme_get_setting('tailpine_h3_color') ?? '#1F2937';
    $h4c = theme_get_setting('tailpine_h4_color') ?? '#1F2937';
    $suc = theme_get_setting('tailpine_success_color') ?? '#14A44D';
    $wc = theme_get_setting('tailpine_warning_color') ?? '#E4A11B';
    $ec = theme_get_setting('tailpine_error_color') ?? '#DC4C64';

    $styles = [
      "--color-primary:$pc;",
      "--color-secondary:$sc;",
      "--color-tertiary:$tc;",
      "--color-body: $bc;",
      "--color-body_bg: $bgc;",
      "--color-h1: $h1c;",
      "--color-h2: $h2c;",
      "--color-h3: $h3c;",
      "--color-h4: $h4c;",
      "--color-success: $suc;",
      "--color-warning: $wc;",
      "--color-error: $ec;",
    ];
    $variables['html_attributes']->setAttribute('style', implode('', $styles));
  }
}

/**
 * Implements hook_preprocess_menu().
 */
function tailpine_preprocess_menu__main(array &$variables): void
{
  $items = $variables["items"];

  $variables['array_for_sdc'] = processNestedArray($items);
}

/**
 * Process a nested array structure recursively
 *
 * @param array $items The input array to process
 * @return array
 */
function processNestedArray($items): array
{
  $result = [];
  $current_path = \Drupal::service('path.current')->getPath(); // Get the current path

  // Get the front page path from configuration
  $front_page = \Drupal::config('system.site')->get('page.front');

  foreach ($items as $item) {
    $newItem = [
      'title' => $item['title'] ?? '',
      'url' => $item['url']?->toString() ?? '#',
      // 'target' => '__self',
      'class' => '',
    ];

    // Add 'active' class if the menu item is in the active trail
    if (!empty($item['in_active_trail'])) {
      $newItem['class'] = 'active';
    }

    // Add active class if the menu item's URL matches the current path
    if (!empty($item['url']) && $item['url']->toString() === $current_path) {
      $newItem['class'] = 'active';
    }

    // Ensure Home is active only when on the front page
    if (($current_path === '/' || $current_path === $front_page) && ($item['url']?->toString() === '/' || $item['url']?->toString() === $front_page)) {
      $newItem['class'] = 'active';
    }

    // Process children recursively if they exist
    if (!empty($item['below']) && is_array($item['below'])) {
      $newItem['children'] = processNestedArray($item['below']);
    }

    $result[] = $newItem;
  }

  return $result;
}

function tailpine_preprocess_page(array &$variables): void
{
  // Load selected header style from theme settings.
  $header_style = theme_get_setting('header_class') ?: 'style4';
  $variables['header_template'] = 'header--' . $header_style;

  // Get the theme setting for fixed header.
  $variables['fixed'] = theme_get_setting('header_fixed');

  // Set the appropriate class based on the setting.
  $variables['header_fixed_class'] = $variables['fixed'] ? 'fixed z-40 w-full' : '';

  // Set the footer template.
  $footer_style = theme_get_setting('footer_class') ?: 'style2';
  $variables['footer_template'] = 'footer--' . $footer_style;

  if (!isset($variables['logo'])) {
    $variables['logo'] = theme_get_setting('logo.url');
  }
}


function tailpine_preprocess_menu(array &$variables) {
  // Get the account menu by its machine name.
  $account_menu_name = 'account';
  // Load the menu tree parameters (e.g., top-level only).
  $parameters = new \Drupal\Core\Menu\MenuTreeParameters();
  // Load the tree.
  $menu_tree = \Drupal::menuTree()->load($account_menu_name, $parameters);
  // Build the tree into a renderable array.
  $manipulated = \Drupal::menuTree()->build($menu_tree);
  // Optionally, extract only the '#items' part if needed.
  $variables['account_menu'] = $manipulated['#items'] ?? [];
  // Get selected header style for menu twig
  $header_style = theme_get_setting('header_class');
  $variables['selected__header_template'] = $header_style;
  // Check if the user is logged in
  $current_user = \Drupal::currentUser();
  // If the user is logged out, remove the "My Account" link from the menu.
  if (!$current_user->isAuthenticated()) {
    foreach ($variables['account_menu'] as $key => $item) {
      if (
        isset($item['url']) &&
        $item['url'] instanceof \Drupal\Core\Url &&
        $item['url']->isRouted() &&
        $item['url']->getRouteName() === 'user.page'
      ) {
        unset($variables['account_menu'][$key]);
      }
    }
  }
}

function tailpine_page_attachments_alter(array &$attachments)
{
  // Retrieve the 'daisyui_enable' setting from the theme configuration.
  $theme = \Drupal::theme()->getActiveTheme()->getName();
  $daisyui_enabled = \Drupal::config($theme . '.settings')->get('daisyui_enable');



  // Check if the 'tailpine/main' library is attached.
  if (!empty($attachments['#attached']['library']) && is_array($attachments['#attached']['library'])) {
    $libraries = &$attachments['#attached']['library'];

    // If DaisyUI is enabled, remove 'tailpine/main' and add 'tailpine/daisyui_styles'.
    if ($daisyui_enabled) {
      // Remove 'tailpine/main' if it's present.dd
      $key = array_search('tailpine/main', $libraries);
      if ($key !== FALSE) {
        unset($libraries[$key]);
      }

      // Add 'tailpine/daisyui_styles' if it's not already attached.
      if (!in_array('tailpine/daisyui_styles', $libraries)) {
        $libraries[] = 'tailpine/daisyui_styles';
      }
    } else {
      // If DaisyUI is not enabled, ensure 'tailpine/main' is attached and 'tailpine/daisyui_styles' is not.
      $key = array_search('tailpine/daisyui_styles', $libraries);
      if ($key !== FALSE) {
        unset($libraries[$key]);
      }

      if (!in_array('tailpine/main', $libraries)) {
        $libraries[] = 'tailpine/main';
      }
    }
  }
}


