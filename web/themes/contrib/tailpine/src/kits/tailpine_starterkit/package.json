{
  "dependencies": {
    "@tailwindcss/postcss": "^4.0.0",
    "postcss": "^8.5.1",
    "postcss-cli": "^11.0.0",
    "tailwindcss": "^4.0.0"
  },
  "scripts": {
    "build": "postcss ./css/main.css -o ./dist/main.css",
    "build:daisy": "DAISY=true postcss ./css/main.css -o ./dist/daisyui.css",
    "watch": "postcss ./css/main.css -o ./dist/main.css --watch"
  },
  "devDependencies": {
    "daisyui": "^5.0.28"
  }
}
