{% stories contact_us with { title: 'Components/Contact Us' } %}

{% story default with {
    name: '1. Contact Us - CTA Section',
    args: { 
      heading_level: 2,
      title: 'Get in Touch',
      subtitle: 'We would love to hear from you. Please reach out for any inquiries or collaborations.'
    }
  } %}
{% embed 'tailpine:contact_us' with { 
  heading_level: heading_level
} %}
  {% block title %}
    {{ title }}
  {% endblock %}
  {% block subtitle %}
    {{ subtitle }}
  {% endblock %}
  {% block cta %}
    {{ cta }}
  {% endblock %}
{% endembed %}
{% endstory %}

{% endstories %}
