{% stories systemmenu with { title: 'Components/System Menu' } %}

{% story default with {
    name: '1. Default',
    args: { 
      plugin_id: 'system_menu_block',
      derivative_plugin_id: 'main',
      configuration: {"label":"Main navigation","label_display":"true","provider":"system"},
      title_prefix: '',
      title_suffix: '',
      title_attributes: [],
      block_label: 'Label Slot',
      block_content: 'Content Slot',
      content: 'Default Content'
    }
  } %}
{% embed 'components:systemmenu' with { 
  plugin_id: plugin_id,
  derivative_plugin_id: derivative_plugin_id,
  configuration: configuration,
  title_prefix: title_prefix,
  title_suffix: title_suffix,
  title_attributes: title_attributes
} %}
  {% block block_label %}
    {{ block_label }}
  {% endblock %}
  {% block block_content %}
    {{ block_content }}
  {% endblock %}
  {% block content %}
    {{ content }}
  {% endblock %}
{% endembed %}
{% endstory %}

{% endstories %}
