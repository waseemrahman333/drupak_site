{"title":"Components\/Tailpine Tabs","parameters":{"server":{"url":"https:\/\/tailpine1.ddev.site\/storybook\/stories\/render"}},"stories":[{"name":"1. Tab Content - Working Multi-tab Example","args":{"children":"<div x-data=\"{ activeTab: 'home' }\" class=\"w-full bg-gray-100 dark:bg-gray-900 p-6\">\n  <div class=\"w-full flex border-b-2 border-gray-400 mb-6\">\n    <button\n      type=\"button\"\n      x-on:click=\"activeTab = 'home'\"\n      x-bind:class=\"activeTab === 'home' ? 'border-b-2 border-primary text-primary' : ''\"\n      class=\"border-b-2 border-body-bg w-1\/3 py-3 text-body dark:text-gray-100 font-bold transition-all duration-200\"\n      role=\"tab\"\n    >\n      Home\n    <\/button>\n    <button\n      type=\"button\"\n      x-on:click=\"activeTab = 'about'\"\n      x-bind:class=\"activeTab === 'about' ? 'border-b-2 border-primary text-primary' : ''\"\n      class=\"border-b-2 border-body-bg w-1\/3 py-3 text-body dark:text-gray-100 font-bold transition-all duration-200\"\n      role=\"tab\"\n    >\n      About\n    <\/button>\n    <button\n      type=\"button\"\n      x-on:click=\"activeTab = 'contact'\"\n      x-bind:class=\"activeTab === 'contact' ? 'border-b-2 border-primary text-primary' : ''\"\n      class=\"border-b-2 border-body-bg w-1\/3 py-3 text-body dark:text-gray-100 font-bold transition-all duration-200\"\n      role=\"tab\"\n    >\n      Contact\n    <\/button>\n  <\/div>\n  <div class=\"bg-white dark:bg-gray-800 p-6 border border-gray-200 dark:border-gray-700\">\n    <div \n      x-show=\"activeTab === 'home'\"\n      x-transition:enter=\"transition ease-out duration-200\"\n      x-transition:enter-start=\"opacity-0\"\n      x-transition:enter-end=\"opacity-100\"\n      role=\"tabpanel\"\n    >\n      <div class=\"space-y-4\">\n        <h2 class=\"text-2xl font-bold text-gray-900 dark:text-gray-100\">Home Tab<\/h2>\n        <p class=\"text-gray-700 dark:text-gray-300\">Welcome to the home tab. This demonstrates the underline tab style with smooth transitions.<\/p>\n      <\/div>\n    <\/div>\n    <div \n      x-show=\"activeTab === 'about'\"\n      x-transition:enter=\"transition ease-out duration-200\"\n      x-transition:enter-start=\"opacity-0\"\n      x-transition:enter-end=\"opacity-100\"\n      role=\"tabpanel\"\n    >\n      <div class=\"space-y-4\">\n        <h2 class=\"text-2xl font-bold text-gray-900 dark:text-gray-100\">About Tab<\/h2>\n        <p class=\"text-gray-700 dark:text-gray-300\">Learn more about our platform and features in this about section.<\/p>\n      <\/div>\n    <\/div>\n    <div \n      x-show=\"activeTab === 'contact'\"\n      x-transition:enter=\"transition ease-out duration-200\"\n      x-transition:enter-start=\"opacity-0\"\n      x-transition:enter-end=\"opacity-100\"\n      role=\"tabpanel\"\n    >\n      <div class=\"space-y-4\">\n        <h2 class=\"text-2xl font-bold text-gray-900 dark:text-gray-100\">Contact Tab<\/h2>\n        <p class=\"text-gray-700 dark:text-gray-300\">Get in touch with us through this contact section.<\/p>\n      <\/div>\n    <\/div>\n  <\/div>\n<\/div>\n"},"parameters":{"server":{"id":"eyJwYXRoIjoidGhlbWVzXC9jdXN0b21cL3RhaWxwaW5lXC9jb21wb25lbnRzXC90YWlscGluZV90YWJzXC90YWJzY29udGVudFwvdGFic2NvbnRlbnQuc3Rvcmllcy50d2lnIiwiaWQiOiJ3b3JraW5nX2V4YW1wbGUifQ%3D%3D"}}}]}