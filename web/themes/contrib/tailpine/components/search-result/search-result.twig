{{ attach_library('tailpine/search-results') }}
{{ title_prefix }}
<h3{{ title_attributes.addClass('search-result__title text-xl font-semibold text-body hover:text-primary transition-colors duration-300 ease-in-out mb-2 tracking-tight') }}>
  <a href="{{ url }}">{{ title }}</a>
</h3>
{{ title_suffix }}

<div class="search-result__snippet-info bg-tertiary border border-secondary rounded-2xl p-5 shadow-sm hover:shadow-md transition-all duration-300">
  {% if snippet %}
    <p{{ content_attributes.addClass('search-result__snippet text-body/80 leading-relaxed mb-3 text-base') }}>
      {{ snippet }}
    </p>
  {% endif %}
  {% if info %}
    <p class="search-result__info text-sm text-secondary font-medium">
      {{ info }}
    </p>
  {% endif %}
</div>
