{#
/**
 * Node Created Date Component
 * 
 * Displays node creation date/time.
 *
 * Available variables:
 * - attributes: HTML attributes.
 * - items: Array of date items.
 * - classes: CSS classes.
 * - nodecreated_utility_classes: Additional Tailwind classes.
 */
#}
{%
  set nodecreated_classes = [
    'text-sm',
    'text-gray-600 dark:text-gray-400',
    'inline-flex items-center gap-1',
  ]|merge(nodecreated_utility_classes ?: [])|merge(classes ?: [])
%}

<span{{ attributes.addClass(nodecreated_classes) }}>
  <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"></path>
  </svg>
  {%- for item in items -%}
    {{ item.content }}
  {%- endfor -%}
</span>