{% stories title with { title: 'Components/Node Title' } %}

{% story default with {
    name: '1. Title - H1 Page Title',
    args: { 
      field_name: 'title',
      field_type: 'string',
      label_display: 'hidden',
      is_inline: false,
      heading_level: 'h1',
      items: [{"content":"Welcome to Our Platform"}],
      title_utility_classes: ["text-4xl","mb-6"]
    }
