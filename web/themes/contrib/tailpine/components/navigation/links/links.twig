{% if links -%}
  {%- if heading -%}
    {%- if heading.level -%}
      <{{ heading.level }}{{ (heading.attributes|default(create_attribute())) }}>{{ heading.text }}</{{ heading.level }}>
    {%- else -%}
      <h2{{ (heading.attributes|default(create_attribute())) }}>{{ heading.text }}</h2>
    {%- endif -%}
  {%- endif -%}
  <ul{{ (attributes|default(create_attribute())) }}>
    {% for item in links %}
      <li{{ (item.attributes|default(create_attribute())) }}>
        {%- if item.link -%}
          {{ item.link }}
        {%- elseif item.text_attributes -%}
          <span{{ (item.text_attributes|default(create_attribute())) }}>{{ item.text }}</span>
        {%- else -%}
          {{ item.text }}
        {%- endif -%}
      </li>
    {% endfor %}
  </ul>
{%- endif %}

