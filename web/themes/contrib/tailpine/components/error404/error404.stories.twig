{% stories error404 with { title: 'Components/error404' } %}

{% story default with {
    name: '1. 404 Error Page',
    args: { 
      title_heading_level: 1,
      subtitle_heading_level: 2,
      title: '404!',
      subtitle: 'The page you are looking for does not exist. It might have been moved or deleted.'
    }
  } %}
{% embed 'tailpine:error404' with { 
  title_heading_level: title_heading_level,
  subtitle_heading_level: subtitle_heading_level
} %}
  {% block title %}
    {{ title }}
  {% endblock %}
  {% block subtitle %}
    {{ subtitle }}
  {% endblock %}
{% endembed %}
{% endstory %}

{% endstories %}
