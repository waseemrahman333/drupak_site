{% stories testimonialstyleone with { title: 'Components/Testimonial   Style One' } %}

{% story default with {
    name: '1. Testimonial Style One - With Quote',
    args: { 
      imageurl: 'https://cdn.pixabay.com/photo/2024/04/02/10/28/bangladesh-8670559_1280.jpg',
      rating: 5,
      heading_level: 2,
      name: 'Michael Chen',
      subtitle: 'Marketing Director, InnovateCo',
      description: 'Working with this team has been transformative for our business. Their attention to detail and commitment to excellence is unmatched. I highly recommend their services to anyone looking for quality results.'
    }
  } %}
{% embed 'components:testimonialstyleone' with { 
  imageurl: imageurl,
  rating: rating,
  heading_level: heading_level
} %}
  {% block name %}
    {{ name }}
  {% endblock %}
  {% block subtitle %}
    {{ subtitle }}
  {% endblock %}
  {% block description %}
    {{ description }}
  {% endblock %}
{% endembed %}
{% endstory %}

{% endstories %}
