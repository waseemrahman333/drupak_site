{%
  set classes = [
    'media',
    'media--type-' ~ bundle,
    not isPublished ? 'media--unpublished',
    view_mode ? 'media--view-mode-' ~ view_mode|clean_class,
    'border',
    'border-secondary/40',
    'rounded-2xl',
    'shadow-sm',
    'hover:shadow-md',
    'transition-all',
    'duration-300',
    'overflow-hidden',
    'p-5',
    'mb-6',
  ]
%}
<article{{ attributes.addClass(classes) }}>
  {{ title_suffix.contextual_links }}
  {% if content %}
    <div class="media-content text-body leading-relaxed">
      {{ content }}
    </div>
  {% endif %}
</article>
