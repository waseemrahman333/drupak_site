{% stories alert with { title: 'Components/Alert' } %}

{% story default with {
    name: '1. Alert - Success',
    args: { 
      messages: 'Your changes have been saved successfully!',
      type: 'success'
    }
  } %}
{% embed 'tailpine:alert' with { 
  messages: messages,
  type: type
} %}{% endembed %}


{% endstory %}

