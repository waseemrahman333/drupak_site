{% stories input with { title: 'Components/Input' } %}

{% story default with {
    name: '1. Text Input',
    args: { 
      default: '<div class="p-6 bg-white">
  <div class="form-item mb-4">
    <label class="block text-sm font-semibold text-gray-900 mb-2">Text Input</label>
    <input type="text" name="username" placeholder="Enter your username" class="!bg-white border border-gray-300 text-gray-900 text-base focus:ring-2 focus:ring-primary focus:border-primary block w-full px-4 py-3 transition-all placeholder:text-gray-400 hover:border-gray-400" />
  </div>
</div>
'
    }
  } %}
{% embed 'components:input' %}
  {% block default %}
    {{ default }}
  {% endblock %}
{% endembed %}
{% endstory %}

