{% story text with {
    name: '7. Input - Text',
    args: { 
      type: 'text',
      value: '',
      placeholder: 'Enter text here...'
    }
  } %}
{% embed 'components:input' with { 
  type: type,
  value: value,
  placeholder: placeholder
} %}
{% endembed %}
{% endstory %}

{% endstories %}
