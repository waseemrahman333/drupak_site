{#
/**
 * @file
 * Theme override for a views exposed form with TailwindCSS styling.
 *
 * Available variables:
 * - form: A render element representing the form.
 * - q: Hidden form element for query string (when clean URLs are off).
 *
 * @see template_preprocess_views_exposed_form()
 */
#}
{% if q is not empty %}
  {#
    This ensures that, if clean URLs are off, the 'q' is added first,
    as a hidden form element, so that it shows up first in the POST URL.
  #}
  {{ q }}
{% endif %}

<div class="views-exposed-form p-4 bg-white dark:bg-gray-900 border border-gray-200 dark:border-gray-700 shadow-sm">
  <div class="flex flex-wrap gap-4 items-end">
    {{ form }}
  </div>
</div>
