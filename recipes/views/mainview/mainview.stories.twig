{% stories mainview with { title: 'Components/Main view' } %}

{% story default with {
    name: '1. Default',
    args: { 
      content: 'Content',
      views_title_utility_classes: [],
      views_header_utility_classes: [],
      views_filters_utility_classes: [],
      views_rows_utility_classes: [],
      views_empty_utility_classes: [],
      views_footer_utility_classes: [],
      views_attachment_before_utility_classes: [],
      views_attachment_after_utility_classes: [],
      views_pager_utility_classes: [],
      views_more_utility_classes: [],
      views_feed_icons_utility_classes: [],
      views_view_wrapper: 'Views wrapper',
      views_view_title: 'Views title',
      views_header: 'Views header',
      views_filters: 'Views filters',
      views_attachment_before: 'Views attachment before',
      views_rows: 'Views rows',
      views_pager: 'Views pager',
      views_attachment_after: 'Views attachment after',
      views_more: 'Views more',
      views_footer: 'Views footer',
      views_feed_icons: 'Views feed icons'
    }
  } %}
{% embed 'components:mainview' with { 
  content: content,
  views_title_utility_classes: views_title_utility_classes,
  views_header_utility_classes: views_header_utility_classes,
  views_filters_utility_classes: views_filters_utility_classes,
  views_rows_utility_classes: views_rows_utility_classes,
  views_empty_utility_classes: views_empty_utility_classes,
  views_footer_utility_classes: views_footer_utility_classes,
  views_attachment_before_utility_classes: views_attachment_before_utility_classes,
  views_attachment_after_utility_classes: views_attachment_after_utility_classes,
  views_pager_utility_classes: views_pager_utility_classes,
  views_more_utility_classes: views_more_utility_classes,
  views_feed_icons_utility_classes: views_feed_icons_utility_classes
} %}
  {% block views_view_wrapper %}
    {{ views_view_wrapper }}
  {% endblock %}
  {% block views_view_title %}
    {{ views_view_title }}
  {% endblock %}
  {% block views_header %}
    {{ views_header }}
  {% endblock %}
  {% block views_filters %}
    {{ views_filters }}
  {% endblock %}
  {% block views_attachment_before %}
    {{ views_attachment_before }}
  {% endblock %}
  {% block views_rows %}
    {{ views_rows }}
  {% endblock %}
  {% block views_pager %}
    {{ views_pager }}
  {% endblock %}
  {% block views_attachment_after %}
    {{ views_attachment_after }}
  {% endblock %}
  {% block views_more %}
    {{ views_more }}
  {% endblock %}
  {% block views_footer %}
    {{ views_footer }}
  {% endblock %}
  {% block views_feed_icons %}
    {{ views_feed_icons }}
  {% endblock %}
{% endembed %}
{% endstory %}

{% endstories %}
